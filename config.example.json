{
  "listen_host": "127.0.0.1",
  "listen_port": 43118,
  "upstream_base_url": "https://gmncode.cn/v1",
  "upstream_api_key": "replace-with-your-key",
  "upstream_chat_path": "/chat/completions",
  "default_model": "gpt-5.4",
  "request_timeout_seconds": 600,
  "request_retry_attempts": 2,
  "request_retry_backoff_seconds": 0.5,
  "log_level": "INFO",
  "model_aliases": {
    "claude-*": "gpt-5.4",
    "claude-sonnet*": "gpt-5.4",
    "claude-opus*": "gpt-5.4",
    "claude-haiku*": "gpt-5.4",
    "claude-sonnet-4-5": "gpt-5.4",
    "sonnet": "gpt-5.4",
    "opus": "gpt-5.4",
    "haiku": "gpt-5.4"
  }
}
